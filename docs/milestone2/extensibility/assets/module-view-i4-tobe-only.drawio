        <mxCell id="E1" value="«use» (1 call per tab)" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#2a7a2a;fontSize=10;fontColor=#2a7a2a;" edge="1" source="MW" target="RT" parent="1">
          <mxGeometry relative="1" as="geometry"/>
