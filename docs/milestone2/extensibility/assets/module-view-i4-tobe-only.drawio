          <mxGeometry x="510" y="74" width="200" height="14" as="geometry"/>
        </mxCell>

        <!-- registerTab helper -->
        <mxCell id="RT" value="registerTab&lt;T&gt;(tab, label)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="170" width="190" height="40" as="geometry"/>
        </mxCell>

        <!-- addObserver helper -->
        <mxCell id="AO" value="addObserver(tab)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="170" width="160" height="40" as="geometry"/>
