        </mxCell>

        <!-- mAllTabs -->
        <mxCell id="MAT" value="mAllTabs&#xa;QList&lt;BaseGraphTab*&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="310" width="170" height="44" as="geometry"/>
