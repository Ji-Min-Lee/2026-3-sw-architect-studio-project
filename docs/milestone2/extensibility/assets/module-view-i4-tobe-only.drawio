        <mxCell id="ANN" value="1 edit per tab:" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="510" y="58" width="100" height="16" as="geometry"/>
