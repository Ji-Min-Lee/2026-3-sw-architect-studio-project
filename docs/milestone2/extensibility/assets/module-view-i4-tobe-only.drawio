        <!-- QTabWidget -->
        <mxCell id="QTW" value="QTabWidget&#xa;(GraphicsTabWidget)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
