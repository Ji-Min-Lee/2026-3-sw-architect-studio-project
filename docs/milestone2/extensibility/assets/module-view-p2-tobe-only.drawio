          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DSP → Engine -->
        <mxCell id="E6" value="init(movement, config)" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#000000;fontSize=10;" edge="1" source="DSP" target="ENG" parent="1">
