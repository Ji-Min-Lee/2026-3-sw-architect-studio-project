        <!-- DSP uses VOs -->
        <mxCell id="E4" value="«use»" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#6e40c9;fontSize=10;" edge="1" source="DSP" target="MS" parent="1">
