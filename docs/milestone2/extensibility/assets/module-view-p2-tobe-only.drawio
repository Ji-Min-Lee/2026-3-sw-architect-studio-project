        <!-- MainWindow -->
        <mxCell id="MW" value="MainWindow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="355" y="80" width="190" height="40" as="geometry"/>
        </mxCell>

        <!-- DSPWorker -->
        <mxCell id="DSP" value="DSPWorker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="355" y="250" width="190" height="40" as="geometry"/>
        </mxCell>

        <!-- MeasurementEngine -->
        <mxCell id="ENG" value="MeasurementEngine" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="335" y="380" width="230" height="40" as="geometry"/>
        </mxCell>

        <!-- Edges: MW constructs VOs -->
        <mxCell id="E1" value="«use»" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#6e40c9;fontSize=10;" edge="1" source="MW" target="MS" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="E2" value="«use»" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#1a6b3c;fontSize=10;" edge="1" source="MW" target="AC" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- MW → DSP -->
        <mxCell id="E3" value="new DSPWorker(raw, movement, config, useOnset)" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#000000;fontSize=10;" edge="1" source="MW" target="DSP" parent="1">
          <mxGeometry relative="1" as="geometry"/>
