<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram name="AS-IS" id="asis-i1">
    <mxGraphModel dx="900" dy="560" grid="0" gridSize="10" pageWidth="700" pageHeight="420">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="TTL" value="AS-IS: Module Uses View — I-1 SessionController" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="0" y="8" width="700" height="24" as="geometry"/>
        </mxCell>

        <!-- MainWindow: god class owning acquisition + domain + presentation -->
        <mxCell id="MW" value="&lt;b&gt;MainWindow&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px;'&gt;949 lines — UI + session + tabs + diagnosis&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="230" y="50" width="240" height="50" as="geometry"/>
        </mxCell>

        <!-- Acquisition layer — all owned directly by MainWindow -->
        <mxCell id="AW" value="TAudioWorker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="180" width="140" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="PW" value="TPlaybackWorker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="180" width="140" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="SW" value="TSimWorker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="370" y="180" width="140" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="DSP" value="DSPWorker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="310" width="140" height="40" as="geometry"/>
