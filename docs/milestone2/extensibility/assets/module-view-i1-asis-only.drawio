        <mxCell id="RA" value="TMasterAudioDataRaw" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="370" y="310" width="160" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="LOG" value="Logger" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="550" y="180" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- Note -->
        <mxCell id="NOTE" value="Problem: MainWindow directly owns&#xa;6 acquisition-layer elements.&#xa;Adding a new source requires&#xa;editing MainWindow." style="shape=note;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;size=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="310" width="155" height="60" as="geometry"/>
        </mxCell>

        <!-- «use» edges from MainWindow to all workers -->
        <mxCell id="E1" value="«use»" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#000000;fontSize=10;" edge="1" source="MW" target="AW" parent="1">
