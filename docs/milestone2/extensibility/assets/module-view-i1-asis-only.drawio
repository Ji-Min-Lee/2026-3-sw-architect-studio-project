        <mxCell id="E6" value="«use»" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#000000;fontSize=10;" edge="1" source="MW" target="LOG" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Workers «use» DSPWorker via dataReady signal -->
        <mxCell id="E7" value="«use»" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#888888;fontSize=10;" edge="1" source="AW" target="DSP" parent="1">
