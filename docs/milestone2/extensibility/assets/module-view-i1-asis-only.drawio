        <mxCell id="E4" value="«use»" style="html=1;dashed=1;endArrow=open;endFill=0;strokeColor=#000000;fontSize=10;" edge="1" source="MW" target="DSP" parent="1">
          <mxGeometry relative="1" as="geometry"/>
