        <!-- Raw params box on DSP→Engine edge -->
        <mxCell id="P2" value="&lt;font color='#cc0000'&gt;init(int, int, double, int, double)&lt;br/&gt;— compiler cannot catch wrong order&lt;/font&gt;" style="text;html=1;strokeColor=#cc0000;fillColor=#fff0f0;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="510" y="255" width="240" height="45" as="geometry"/>
        </mxCell>

        <!-- Note -->
        <mxCell id="NOTE" value="Problems:&lt;br/&gt;① bph(int) and sampleRate(int) can&lt;br/&gt;   be silently swapped&lt;br/&gt;② No domain grouping — watch&lt;br/&gt;   properties mixed with signal config&lt;br/&gt;③ 6 unrelated args at call site" style="shape=note;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cc0000;fontSize=10;size=12;align=left;" vertex="1" parent="1">
