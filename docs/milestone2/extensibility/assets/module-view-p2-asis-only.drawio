<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram name="AS-IS" id="asis">
    <mxGraphModel dx="1000" dy="580" grid="0" gridSize="10" pageWidth="820" pageHeight="420">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="TTL" value="AS-IS: 5 Raw Parameters — No Domain Boundary" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="0" y="8" width="820" height="24" as="geometry"/>
        </mxCell>

        <!-- MainWindow -->
        <mxCell id="MW" value="MainWindow" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="50" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- DSPWorker -->
        <mxCell id="DSP" value="DSPWorker" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="150" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- MeasurementEngine -->
        <mxCell id="ENG" value="MeasurementEngine" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="260" width="220" height="40" as="geometry"/>
        </mxCell>

        <!-- Raw params box on MW→DSP edge -->
        <mxCell id="P1" value="&lt;font color='#cc0000'&gt;int sampleRate, int bph,&lt;br/&gt;double liftAngle, int avgPeriod,&lt;br/&gt;double highPass, bool useOnset&lt;/font&gt;" style="text;html=1;strokeColor=#cc0000;fillColor=#fff0f0;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="510" y="135" width="240" height="55" as="geometry"/>
