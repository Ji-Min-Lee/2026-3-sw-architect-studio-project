@startuml
skinparam linetype ortho
skinparam rectangle {
    BackgroundColor<<input>> LightSkyBlue
    BackgroundColor<<shared>> LightYellow
    BackgroundColor<<dsp>> LightGreen
    BackgroundColor<<analysis>> LightSalmon
    BackgroundColor<<ui>> Lavender
}

package "입력 레이어 (Audio Source)" <<input>> {
    rectangle "TAudioWorker\n마이크 실시간 캡처\n(Qt QAudioSource)" as AW
    rectangle "TPlaybackWorker\nWAV 파일 재생" as PW
    rectangle "TSimWorker\n시계 소리 시뮬레이션\n(WatchSynthStream)" as SW
}

package "공유 버퍼" <<shared>> {
    rectangle "TMasterAudioDataRaw\nfloat 링버퍼 (30초)\n+ 뮤텍스" as SA
}

package "DSP 파이프라인 (C 라이브러리)" <<dsp>> {
    rectangle "tg_hpf_t\nDC Blocker\n(200Hz HPF)" as HPF
    rectangle "tg_envelope_t\n엔벨로프 검출\n(정류 + LPF)" as ENV
    rectangle "Detector\n침묵 기반 온셋 검출\nA이벤트(unlock), C이벤트(drop)" as DET
    rectangle "Bph\nBPH 자동 감지\n(Rayleigh 위상 점수)\n+ PLL 동기 추적" as BPH
    rectangle "Timegrapher (tg_context_t)\n파이프라인 총괄" as TG
}

package "분석 레이어 (MainWindow 내부)" <<analysis>> {
    rectangle "RollingLeastSquares\n레이트 오차 계산\n(선형 회귀)" as RLS
    rectangle "RollingAverage\n비트 오차 / 진폭 평균" as RA
    rectangle "TRateErrorEvents\nTBeatErrorEvents\nTAmplitudeErrorEvents" as STRUCTS
}

package "UI 레이어 (Qt)" <<ui>> {
    rectangle "MainWindow\n전체 오케스트레이터\n(Qt Signals/Slots)" as MW
    rectangle "SoundImageWidget\n타임그래퍼 사운드이미지\n(QWidget)" as SIW
    rectangle "SoundImageRenderer\n사운드이미지 픽셀 렌더링" as SIR
    rectangle "QCustomPlot\n레이트 / 비트오차 그래프" as CP
    rectangle "WavStreamWriter\nWAV 파일 저장" as WSW
}

AW --> SA : PCM float 샘플
PW --> SA : PCM float 샘플
SW --> SA : 시뮬레이션 샘플

SA --> MW : 프레임 단위 읽기
MW --> HPF : 샘플 전달
HPF --> ENV
ENV --> DET
DET --> BPH : A/C 이벤트
BPH --> TG : BPH + 동기 상태
TG --> MW : tg_event_t

MW --> RLS
MW --> RA
RLS --> STRUCTS
RA --> STRUCTS
STRUCTS --> CP

MW --> SIR
SIR --> SIW
MW --> WSW

@enduml